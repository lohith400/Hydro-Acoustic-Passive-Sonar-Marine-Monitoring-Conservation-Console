# ============================================================
# HYDRO-ACOUSTIC SONAR PROJECT — .gitignore
# Only source code is pushed. All datasets, binaries, and
# generated node modules / builds are excluded.
# ============================================================

# --- Python Bytecode & Cache ---
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Virtual Environment ---
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# --- Environment Variables ---
.env
.env.*

# --- Node / Frontend Build & Deps ---
node_modules/
dist/
dist-ssr/
*.local

# ============================================================
# DATASET DIRECTORIES (auto-downloaded, never committed)
# ============================================================
# DeepShip — cloned from GitHub
DeepShip/

# Watkins Marine Mammal Sound Database + all staged raw audio
real_raw_data/

# Any other raw audio or data directories
data/
datasets_cache/
*.wav
*.mp3
*.flac
*.ogg
*.aiff

# HuggingFace Hub local cache
~/.cache/huggingface/
.cache/

# ============================================================
# TRAINED MODEL WEIGHTS (large binaries, re-trainable)
# ============================================================
*.h5
*.keras
*.pb
*.pt
*.pth
*.onnx
*.pkl
*.joblib

# SavedModel directories
saved_model/

# ============================================================
# LOGS & TEMP FILES
# ============================================================
*.log
*.tmp
*.bak
logs/
runs/

# ============================================================
# IDE / EDITOR SETTINGS
# ============================================================
.vscode/
.idea/
*.code-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ============================================================
# OS-SPECIFIC FILES
# ============================================================
.DS_Store
Thumbs.db
Desktop.ini
